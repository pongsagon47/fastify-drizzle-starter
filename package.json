{
  "name": "fastify-drizzle-starter",
  "version": "1.0.0",
  "description": "Fastify + Drizzle + TypeScript Starter",
  "main": "index.js",
  "keywords": [
    "fastify",
    "drizzle",
    "typescript",
    "starter"
  ],
  "author": "TAK",
  "license": "MIT",
  "type": "module",
  "pnpm": {
    "allowedDeprecatedVersions": {
      "@esbuild-kit/core-utils": "*",
      "@esbuild-kit/esm-loader": "*"
    },
    "ignoredBuiltDependencies": [
      "bcrypt",
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.4",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "ejs": "^5.0.1",
    "fastify": "^5.8.2",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "^5.10.0",
    "mongodb": "^7.1.0",
    "mysql2": "^3.19.0",
    "nodemailer": "^8.0.2",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/ejs": "^3.1.5",
    "@types/node": "^25.3.5",
    "@types/nodemailer": "^7.0.11",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
