NODE_ENV=development
PORT=3800

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=dev
DB_PASSWORD=dev
DB_NAME=fastify_dev
DB_SSL_CERT=
DB_SSL_KEY=
DB_SSL_CA=

#--------------------------------------------------------------------
# JWT
#--------------------------------------------------------------------
JWT_SECRET=your-super-secret-key-minimum-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

#--------------------------------------------------------------------
# CORS
#--------------------------------------------------------------------
ALLOWED_ORIGINS=


#--------------------------------------------------------------------
# MAILER
#--------------------------------------------------------------------
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=
MAIL_FROM=
MAIL_FROM_NAME=

#--------------------------------------------------------------------
# UPLOAD
#--------------------------------------------------------------------
UPLOAD_PATH=uploads

#--------------------------------------------------------------------
# REDIS (optional — leave blank to disable caching & in-memory rate limit)
#--------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_TTL=60

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
APP_URL=http://localhost:3000
PASSWORD_RESET_EXPIRES_IN=1800

#--------------------------------------------------------------------
# MONGODB (optional — for request logging)
#--------------------------------------------------------------------
MONGO_URL=mongodb://localhost:27017/fastify_logs
MONGO_LOG_TTL_DAYS=30